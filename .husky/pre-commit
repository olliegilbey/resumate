#!/usr/bin/env bash
#
# Optimized Pre-commit Hook for Resumate
# Fail-fast ordering: Secrets → Lint → Conditional rebuilds → Tests
#
# Philosophy: Heavy by design (10-60s) - Last defense before public repo
# Fast path (no rebuilds): ~10-15s
# WASM rebuild path: ~45-60s
#
# Skip only in emergency: git commit --no-verify

# Husky's _/h wrapper invokes hooks with `sh -e` (dash on Linux), which
# ignores the bash shebang and chokes on bash-only syntax below (arrays,
# [[ ]], etc.). Re-exec under bash so the hook runs identically on
# macOS (/bin/sh is bash-compatible) and Linux/CI sandboxes (dash).
if [ -z "${BASH_VERSION:-}" ]; then
  exec bash "$0" "$@"
fi

set -e  # Exit on first error

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Track timing
START_TIME=$(date +%s)

# Source build limits from justfile (single source of truth)
WASM_MAX_RAW_MB=$(just --evaluate wasm_max_raw_mb)
WASM_MAX_GZIP_MB=$(just --evaluate wasm_max_gzip_mb)
PRECOMMIT_MAX_DURATION=$(just --evaluate precommit_max_duration)

echo ""
printf "${BLUE}🔒 Pre-commit: Fail-fast validation${NC}\n"
echo ""

# ============================================
# PHASE 1: SECRET SCANNING (~5s)
# Fail immediately if secrets/PII detected
# ============================================
printf "${BLUE}→ Phase 1/7: Secret scanning (gitleaks, ripsecrets, trufflehog)${NC}\n"

# 1.1 Gitleaks (filesystem scan, uses .gitleaks.toml)
# Use 'detect --no-git' to scan all current files (no git history)
# Catches secrets in: committed files, staged, unstaged, untracked
GITLEAKS_OUTPUT=$(gitleaks detect --no-banner --verbose --no-git 2>&1)
if ! echo "$GITLEAKS_OUTPUT" | grep -q "no leaks found"; then
  printf "${RED}❌ Gitleaks found secrets or PII in repository!${NC}\n"
  echo "$GITLEAKS_OUTPUT"
  printf "${YELLOW}Fix and retry. Add to .gitignore or .gitleaks.toml allowlist if false positive.${NC}\n"
  exit 1
fi
printf "${GREEN}  ✓${NC} Gitleaks: 0 secrets (all files)"

# 1.2 Ripsecrets (filesystem scan)
if ! ripsecrets --strict-ignore . 2>&1; then
  printf "${RED}❌ Ripsecrets found secrets!${NC}\n"
  exit 1
fi
printf "${GREEN}  ✓${NC} Ripsecrets: 0 secrets"

# 1.3 Trufflehog (deep scan on staged files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED_FILES" ]; then
  TRUFFLEHOG_OUTPUT=$(echo "$STAGED_FILES" | xargs trufflehog filesystem --no-update --only-verified --json 2>&1 || true)
  # Check if any JSON objects were output (findings)
  if echo "$TRUFFLEHOG_OUTPUT" | grep -q '"DetectorType"'; then
    printf "${RED}❌ Trufflehog found verified secrets!${NC}\n"
    echo "$TRUFFLEHOG_OUTPUT" | grep '"DetectorType"'
    exit 1
  fi
  printf "${GREEN}  ✓${NC} Trufflehog: 0 verified secrets"
fi

printf "${GREEN}✅ Phase 1 complete: No secrets detected${NC}\n"
echo ""

# ============================================
# PHASE 1.5: AUTO-FORMAT STAGED (lint-staged, ~1-3s)
# Prettier --write + eslint --fix on staged files only.
# Re-stages under the hood. Complements Phase 2's full-project checks.
# ============================================
printf "${BLUE}→ Phase 1.5/7: Auto-format staged${NC}\n"
if ! bun x lint-staged 2>&1; then
  printf "${RED}❌ lint-staged failed${NC}\n"
  exit 1
fi
printf "${GREEN}✅ Phase 1.5 complete: staged files formatted${NC}\n"
echo ""

# ============================================
# PHASE 2: LINT + TYPECHECK (~5-10s)
# Fast validation before expensive operations
# ============================================
printf "${BLUE}→ Phase 2/7: Lint & typecheck${NC}\n"

# Check which files are staged
TS_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)
RS_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.rs$' || true)

# 2.1 TypeScript linting (if TS files changed)
if [ -n "$TS_STAGED" ]; then
  printf "${YELLOW}  → ESLint (TS files changed)${NC}\n"
  if ! bun x eslint --fix $TS_STAGED 2>&1; then
    printf "${RED}❌ ESLint failed${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} ESLint passed"

  # Stage fixed files
  git add $TS_STAGED
fi

# 2.2 TypeScript typecheck (if TS files changed)
if [ -n "$TS_STAGED" ]; then
  printf "${YELLOW}  → TypeScript typecheck${NC}\n"
  if ! bun x tsc --noEmit 2>&1; then
    printf "${RED}❌ TypeScript typecheck failed${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} TypeScript typecheck passed"
fi

# 2.3 Rust formatting (if Rust files changed)
if [ -n "$RS_STAGED" ]; then
  printf "${YELLOW}  → Rust formatting${NC}\n"
  if ! cargo fmt --check --quiet 2>&1; then
    printf "${YELLOW}  → Auto-formatting Rust code${NC}\n"
    cargo fmt --all
    git add $RS_STAGED
  fi
  printf "${GREEN}  ✓${NC} Rust formatted"
fi

# 2.4 Clippy (if Rust files changed)
if [ -n "$RS_STAGED" ]; then
  printf "${YELLOW}  → Clippy${NC}\n"
  if ! cargo clippy --all-targets --quiet -- -D warnings 2>&1; then
    printf "${RED}❌ Clippy found warnings${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} Clippy passed (zero warnings)"
fi

# 2.5 Knip dead-code scan (fast — ~3s via bun runtime)
# Keeps dead exports/files from accumulating. Runs under bun explicitly because
# oxc-parser 0.121.x allocates a 6 GiB ArrayBuffer that exceeds Node 22's limit.
printf "${YELLOW}  → Knip dead-code scan${NC}\n"
if ! bun --bun x knip 2>&1; then
  printf "${RED}❌ Knip found dead code — fix or add to knip.json with a reason in AGENTS.md${NC}\n"
  exit 1
fi
printf "${GREEN}  ✓${NC} Knip clean"

# 2.6 Line-cap escape-hatch guard.
# ESLint enforces the 250-line cap, but can't forbid its own disable comment.
# This grep closes the loophole so agents can't silently bypass the guardrail.
printf "${YELLOW}  → Line-cap escape-hatch check${NC}\n"
if ! just check-line-caps >/dev/null 2>&1; then
  printf "${RED}❌ Found eslint-disable max-lines in source — split the module instead${NC}\n"
  just check-line-caps
  exit 1
fi
printf "${GREEN}  ✓${NC} No line-cap disables"

printf "${GREEN}✅ Phase 2 complete: Lint & typecheck passed${NC}\n"
echo ""

# ============================================
# PHASE 3: WASM REBUILD (~1-45s, conditional)
# Only rebuild if WASM sources changed
# ============================================
printf "${BLUE}→ Phase 3/7: WASM freshness check${NC}\n"

WASM_REBUILT=false

# Check if WASM sources are staged
WASM_SOURCES=(
  "crates/resume-wasm"
  "crates/resume-typst"
  "crates/resume-core"
  "crates/shared-types"
  "typst/templates"
  "typst/fonts"
)

wasm_staged=false
for source in "${WASM_SOURCES[@]}"; do
  if git diff --cached --name-only | grep -q "^${source}/"; then
    wasm_staged=true
    break
  fi
done

if [ "$wasm_staged" = true ]; then
  printf "${YELLOW}  → WASM sources changed - checking freshness${NC}\n"

  # Run check-wasm.sh --fresh (handles rebuild + staging)
  if ./scripts/check-wasm.sh --fresh; then
    WASM_REBUILT=true
    printf "${GREEN}  ✓${NC} WASM rebuilt and staged"
  else
    printf "${RED}❌ WASM rebuild failed${NC}\n"
    exit 1
  fi
else
  printf "${GREEN}  ✓${NC} WASM sources unchanged (skipped)"
fi

if [ "$WASM_REBUILT" = true ]; then
  printf "${GREEN}✅ Phase 3 complete: WASM rebuilt${NC}\n"
else
  printf "${GREEN}✅ Phase 3 complete: WASM up-to-date${NC}\n"
fi
echo ""

# ============================================
# PHASE 4: BUNDLE SIZE CHECK (<1s)
# Enforce WASM binary size limits (from justfile)
# ============================================
printf "${BLUE}→ Phase 4/7: Bundle size validation${NC}\n"

if bash ./scripts/check-bundle-size.sh "$WASM_MAX_RAW_MB" "$WASM_MAX_GZIP_MB"; then
  printf "${GREEN}✅ Phase 4 complete: Bundle size within limits${NC}\n"
else
  printf "${RED}❌ Bundle size check failed${NC}\n"
  exit 1
fi
echo ""

# ============================================
# PHASE 5: WASM TESTS (~10s, conditional)
# Only run if WASM was rebuilt in this commit
# ============================================
printf "${BLUE}→ Phase 5/7: WASM-dependent tests${NC}\n"

if [ "$WASM_REBUILT" = true ]; then
  printf "${YELLOW}  → Running WASM-dependent Rust tests${NC}\n"

  # Tests that depend on WASM: typst_generation_test
  if ! cargo test --test typst_generation_test --quiet 2>&1; then
    printf "${RED}❌ WASM tests failed${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} WASM tests passed"
else
  printf "${GREEN}  ✓${NC} WASM unchanged (tests skipped)"
fi

if [ "$WASM_REBUILT" = true ]; then
  printf "${GREEN}✅ Phase 5 complete: WASM tests passed${NC}\n"
else
  printf "${GREEN}✅ Phase 5 complete: WASM tests skipped${NC}\n"
fi
echo ""

# ============================================
# PHASE 6: TYPE SYNC (~5s, conditional)
# Only regenerate if shared-types changed
# ============================================
printf "${BLUE}→ Phase 6/7: Type synchronization${NC}\n"

if echo "$RS_STAGED" | grep -q "crates/shared-types/"; then
  printf "${YELLOW}  → shared-types changed - regenerating schema + TS types${NC}\n"

  # Generate JSON Schema from Rust (requires schema feature for schemars)
  if ! cargo run --bin generate_schema -p shared-types --features schema --quiet 2>&1; then
    printf "${RED}❌ Schema generation failed${NC}\n"
    exit 1
  fi

  # Generate TS types from schema
  if ! bun types:gen 2>&1; then
    printf "${RED}❌ TS type generation failed${NC}\n"
    exit 1
  fi

  # Stage generated files
  git add schemas/resume.schema.json lib/types/generated-resume.ts

  printf "${GREEN}  ✓${NC} Types synchronized and staged"
else
  printf "${GREEN}  ✓${NC} shared-types unchanged (skipped)"
fi

printf "${GREEN}✅ Phase 6 complete: Types synchronized${NC}\n"
echo ""

# ============================================
# PHASE 7: RUST TESTS (conditional)
# Only run if Rust files changed (not WASM-only)
# ============================================
printf "${BLUE}→ Phase 7/7: Rust test suite${NC}\n"

if [ -n "$RS_STAGED" ]; then
  printf "${YELLOW}  → Running full Rust test suite${NC}\n"

  if ! cargo test --all --quiet 2>&1; then
    printf "${RED}❌ Rust tests failed${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} Rust tests passed"
else
  printf "${GREEN}  ✓${NC} No Rust files changed (skipped)"
fi

# TypeScript tests (if TS or shared-types changed)
if [ -n "$TS_STAGED" ] || echo "$RS_STAGED" | grep -q "crates/shared-types/"; then
  printf "${YELLOW}  → Running TypeScript tests${NC}\n"

  # Use package.json script directly (not `just test-ts`) for infrastructure validation
  # Both call vitest, but pre-commit needs specific flags (--run, --reporter=dot)
  if ! bun run test --run --reporter=dot 2>&1; then
    printf "${RED}❌ TypeScript tests failed${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} TypeScript tests passed"

  # CI-sim: re-run typecheck against the template (CI has no gist access, so
  # this catches the "works locally, fails in CI" class of bugs caused by
  # diverging data/resume-data.json PII vs data/resume-data-template.json).
  if [ -f data/resume-data.json ] && [ -f data/resume-data-template.json ]; then
    printf "${YELLOW}  → CI-sim: typecheck against template${NC}\n"
    cp data/resume-data.json "$TMPDIR/.precommit-resume-data.json.bak" 2>/dev/null || \
      cp data/resume-data.json /tmp/.precommit-resume-data.json.bak
    cp data/resume-data-template.json data/resume-data.json
    TEMPLATE_CHECK_OK=true
    bun x tsc --noEmit 2>&1 || TEMPLATE_CHECK_OK=false
    # Restore real data file regardless of outcome
    if [ -f "$TMPDIR/.precommit-resume-data.json.bak" ]; then
      mv "$TMPDIR/.precommit-resume-data.json.bak" data/resume-data.json
    else
      mv /tmp/.precommit-resume-data.json.bak data/resume-data.json
    fi
    if [ "$TEMPLATE_CHECK_OK" != "true" ]; then
      printf "${RED}❌ CI-sim typecheck failed against template — CI will fail${NC}\n"
      printf "${YELLOW}  Fix: update data/resume-data-template.json to match real data shape${NC}\n"
      exit 1
    fi
    printf "${GREEN}  ✓${NC} CI-sim typecheck passed"
  fi
fi

# Data validation (if data files changed)
DATA_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^data/.*\.json$' || true)
if [ -n "$DATA_STAGED" ]; then
  printf "${YELLOW}  → Validating data files${NC}\n"

  for file in $DATA_STAGED; do
    if ! node scripts/validate-compendium.mjs "$file" 2>&1; then
      printf "${RED}❌ Data validation failed: $file${NC}\n"
      exit 1
    fi
  done
  printf "${GREEN}  ✓${NC} Data validation passed"
fi

# Doc verification (if docs changed)
DOCS_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(md)$' || true)
if [ -n "$DOCS_STAGED" ]; then
  printf "${YELLOW}  → Verifying documentation${NC}\n"

  if ! bash scripts/verify-docs.sh 2>&1; then
    printf "${RED}❌ Documentation verification failed${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} Documentation verified"
fi

printf "${GREEN}✅ Phase 7 complete: All tests passed${NC}\n"
echo ""

# ============================================
# TIMING ENFORCEMENT (from justfile)
# ============================================
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

# Enforce timing SLO (sourced from justfile)
# Based on testing: Fast path=2s, WASM rebuild=39s, threshold=70s
if (( DURATION > PRECOMMIT_MAX_DURATION )); then
  printf "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
  printf "${RED}❌ Pre-commit exceeded timing SLO!${NC}\n"
  printf "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
  echo ""
  echo "  Duration: ${DURATION}s (limit: ${PRECOMMIT_MAX_DURATION}s)"
  echo ""
  echo "  Investigate performance regression:"
  echo "    - Check for excessive WASM rebuild time"
  echo "    - Profile secret scanning (should be <5s)"
  echo "    - Check test suite duration"
  echo ""
  echo "  To adjust limit: Edit justfile precommit_max_duration"
  echo "  To bypass (emergency only): git commit --no-verify"
  exit 1
fi

# ============================================
# SUMMARY
# ============================================
printf "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
printf "${GREEN}✅ All pre-commit checks passed!${NC}\n"
printf "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
echo ""
echo "  Duration: ${DURATION}s"
echo ""
echo "  Phases:"
echo "    ✓ Secret scanning"
echo "    ✓ Lint & typecheck"
if [ "$WASM_REBUILT" = true ]; then
  echo "    ✓ WASM rebuild"
else
  echo "    ✓ WASM check"
fi
echo "    ✓ Bundle size"
echo "    ✓ Tests"
echo "    ✓ Type sync"
echo "    ✓ Validation"
echo ""
