# ---------------------------------------------------------------------------
# Resumate environment variables
# Copy to .env.local and fill in values. .env.local is gitignored.
# ---------------------------------------------------------------------------

# --- Client-side (public; inlined into the browser bundle) -----------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Server-side (never exposed to the client) -----------------------------
# Cloudflare Turnstile secret used by /api/contact-card and /api/resume/*
TURNSTILE_SECRET_KEY=

# Contact information surfaced via /api/contact-card (vCard download)
CONTACT_EMAIL_PERSONAL=
CONTACT_EMAIL_PROFESSIONAL=
CONTACT_PHONE=

# Private gist hosting resume-data.json (pulled at build time on Vercel)
RESUME_DATA_GIST_URL=

# --- Turnstile dev-only escape hatch ---------------------------------------
# Set BOTH of the following to skip Cloudflare Turnstile verification during
# local `next dev`:
#   - NODE_ENV=development  (Next.js sets this automatically for `next dev`)
#   - ENABLE_TURNSTILE_DEV_BYPASS=true
#
# The helper in lib/turnstile.ts requires BOTH conditions. A single-flag check
# (e.g. `NODE_ENV !== "production"`) would also fire on Vercel preview deploys,
# silently disabling the captcha there. Do NOT set this flag in production or
# in preview environments.
#
# DO NOT set in prod/preview.
ENABLE_TURNSTILE_DEV_BYPASS=false
